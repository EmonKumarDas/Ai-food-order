<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Shop AI Reports</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
  <style>
    .markdown-body { font-size: 15px; line-height: 1.6; color: #2c3e50; }
    .markdown-body h1, .markdown-body h2, .markdown-body h3, .markdown-body h4 { margin-top: 20px; margin-bottom: 10px; font-weight: 600; color: #1a252f; }
    .markdown-body h4 { font-size: 16px; }
    .markdown-body p { margin-bottom: 15px; }
    .markdown-body ul, .markdown-body ol { margin-bottom: 15px; padding-left: 25px; }
    .markdown-body li { margin-bottom: 5px; }
    .markdown-body strong { font-weight: bold; color: #000; }
    .report-table { width: 100%; border-collapse: collapse; margin-top: 15px; font-size: 14px; }
    .report-table th { background: #2c3e50; color: white; padding: 10px 12px; text-align: left; font-weight: 600; }
    .report-table td { padding: 10px 12px; border-bottom: 1px solid #eee; }
    .report-table tr:hover { background: #f8f9fa; }
    .badge { display: inline-block; padding: 3px 10px; border-radius: 12px; font-size: 12px; font-weight: bold; }
    .badge-high { background: #d4edda; color: #155724; }
    .badge-medium { background: #fff3cd; color: #856404; }
    .badge-risk { background: #f8d7da; color: #721c24; }
    .mood-bar { display: flex; height: 20px; border-radius: 10px; overflow: hidden; }
    .mood-pos { background: #2ed573; }
    .mood-neu { background: #f1c40f; }
    .mood-neg { background: #ff4757; }
    @media (max-width: 768px) {
      .report-table { font-size: 12px; }
      .report-table th, .report-table td { padding: 6px 8px; }
    }
  </style>
</head>
<body>
  <nav class="navbar">
    <div class="container">
      <a href="/shop/dashboard" class="brand">👨‍🍳 Shop Portal</a>
      <div class="nav-links">
        <span style="margin-left: 20px;">Shop: <%= shop.shop_name %></span>
        <a href="/logout" style="color: var(--danger);">Logout</a>
      </div>
    </div>
  </nav>

  <div class="container dashboard-grid">
    <div class="sidebar">
      <ul class="sidebar-menu">
        <li><a href="/shop/dashboard">Dashboard</a></li>
        <li><a href="/shop/orders">Orders</a></li>
        <li><a href="/shop/menu">Menu Management</a></li>
        <li><a href="/shop/reviews">Reviews & Alerts</a></li>
        <li><a href="/shop/reports" class="active">AI Reports ✨</a></li>
      </ul>
    </div>

    <div class="main-content">
      <h2 style="margin-bottom: 20px;">AI Business Reports</h2>
      
      <div style="display: flex; gap: 10px; margin-bottom: 20px; flex-wrap: wrap;">
        <button class="btn btn-primary" onclick="showTab('daily')">Daily Summary</button>
        <button class="btn" style="background: #e0e0e0; color: #333;" onclick="showTab('weekly')">Weekly Insights</button>
        <button class="btn" style="background: #e0e0e0; color: #333;" onclick="showTab('loyalty')">🤝 Customer Loyalty</button>
        <button class="btn" style="background: #e0e0e0; color: #333;" onclick="showTab('growth')">📈 Growth Suggestions</button>
      </div>

      <!-- Daily Report Tab -->
      <div id="tab-daily" class="card">
        <h3>Today's Sentiment</h3>
        <div style="max-width: 300px; margin: 20px auto;">
          <canvas id="dailyChart"></canvas>
        </div>
        <div style="background: #f8f9fa; padding: 20px; border-radius: 8px; border-left: 4px solid var(--primary);">
          <h4 style="color: var(--primary); margin-bottom: 10px;">✨ AI Daily Summary
            <button id="btn-trans-daily" class="btn" style="float: right; padding: 4px 8px; font-size: 12px; background: #eee; color: #333;" onclick="toggleTranslate('daily')">🇧🇩 Bangla</button>
          </h4>
          <div id="daily-text" class="markdown-body" style="color: #333;">Loading...</div>
        </div>
      </div>

      <!-- Weekly Report Tab -->
      <div id="tab-weekly" class="card" style="display: none;">
        <h3>Weekly Performance</h3>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin: 20px 0;">
          <div>
            <h4>Top 5 Best Rated</h4>
            <ul id="top-products" style="padding-left: 20px; margin-top: 10px;"></ul>
          </div>
          <div>
            <h4>Needs Improvement</h4>
            <ul id="worst-products" style="padding-left: 20px; margin-top: 10px; color: var(--danger);"></ul>
          </div>
        </div>
        <!-- Peak Time Analysis -->
        <div style="margin: 20px 0;">
          <h4>⏰ Peak Time Analysis</h4>
          <p style="color: #666; font-size: 13px; margin-bottom: 10px;">Which hours do customers submit the most reviews and what is their mood?</p>
          <table class="report-table">
            <thead>
              <tr>
                <th>Hour</th>
                <th>Reviews</th>
                <th>Avg Rating</th>
                <th>Mood Breakdown</th>
              </tr>
            </thead>
            <tbody id="peak-time-body"></tbody>
          </table>
        </div>
        <div style="background: #f8f9fa; padding: 20px; border-radius: 8px; border-left: 4px solid #3498db;">
          <h4 style="color: #3498db; margin-bottom: 10px;">✨ AI Weekly Insight
            <button id="btn-trans-weekly" class="btn" style="float: right; padding: 4px 8px; font-size: 12px; background: #eee; color: #333;" onclick="toggleTranslate('weekly')">🇧🇩 Bangla</button>
          </h4>
          <div id="weekly-text" class="markdown-body" style="color: #333;">Loading...</div>
        </div>
      </div>

      <!-- Loyalty Report Tab -->
      <div id="tab-loyalty" class="card" style="display: none;">
        <h3>Customer Loyalty Prediction</h3>
        <div style="display: flex; justify-content: space-around; margin: 20px 0; padding: 20px; background: #f1f2f6; border-radius: 8px;">
          <div style="text-align: center;"><strong>High Loyalty:</strong> <div id="loyalty-high" style="color: var(--success); font-size: 24px; font-weight: bold;">0</div></div>
          <div style="text-align: center;"><strong>Medium Loyalty:</strong> <div id="loyalty-medium" style="color: #f1c40f; font-size: 24px; font-weight: bold;">0</div></div>
          <div style="text-align: center;"><strong>At Risk:</strong> <div id="loyalty-risk" style="color: var(--danger); font-size: 24px; font-weight: bold;">0</div></div>
        </div>
        <!-- Customer Details Table -->
        <div style="margin: 20px 0;">
          <h4>👥 Customer Details</h4>
          <table class="report-table">
            <thead>
              <tr>
                <th>Customer</th>
                <th>Orders</th>
                <th>Avg Rating</th>
                <th>Sentiment</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody id="loyalty-details-body"></tbody>
          </table>
        </div>
        <div style="background: #f8f9fa; padding: 20px; border-radius: 8px; border-left: 4px solid #e67e22;">
          <h4 style="color: #e67e22; margin-bottom: 10px;">✨ AI Retention Strategies
            <button id="btn-trans-loyalty" class="btn" style="float: right; padding: 4px 8px; font-size: 12px; background: #eee; color: #333;" onclick="toggleTranslate('loyalty')">🇧🇩 Bangla</button>
          </h4>
          <div id="loyalty-text" class="markdown-body" style="color: #333;">Loading...</div>
        </div>
      </div>

      <!-- Growth Report Tab -->
      <div id="tab-growth" class="card" style="display: none;">
        <h3>Business Growth Suggestions</h3>
        <div style="display: flex; justify-content: space-between; margin: 20px 0; padding: 20px; background: #f1f2f6; border-radius: 8px;">
          <div><strong>Total Revenue (30 days):</strong> <span id="growth-rev" style="color: var(--success); font-size: 20px;"></span></div>
          <div><strong>Average Sentiment:</strong> <span id="growth-sent" style="font-size: 20px;"></span>/1.0</div>
        </div>
        <div style="background: #f8f9fa; padding: 20px; border-radius: 8px; border-left: 4px solid #9b59b6;">
          <h4 style="color: #9b59b6; margin-bottom: 10px;">✨ AI Growth Actions
            <button id="btn-trans-growth" class="btn" style="float: right; padding: 4px 8px; font-size: 12px; background: #eee; color: #333;" onclick="toggleTranslate('growth')">🇧🇩 Bangla</button>
          </h4>
          <div id="growth-text" class="markdown-body" style="color: #333;">Loading...</div>
        </div>
      </div>

    </div>
  </div>

  <script>
    const rawData = { daily: '', weekly: '', loyalty: '', growth: '' };
    const translations = { daily: '', weekly: '', loyalty: '', growth: '' };
    const currentLang = { daily: 'en', weekly: 'en', loyalty: 'en', growth: 'en' };

    async function toggleTranslate(section) {
      const btn = document.getElementById(`btn-trans-${section}`);
      const textDiv = document.getElementById(`${section}-text`);
      
      if (currentLang[section] === 'en') {
        btn.textContent = '⏳ Translating...';
        btn.disabled = true;
        
        if (!translations[section]) {
          try {
            const res = await fetch('/api/reports/translate', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ text: rawData[section], targetLang: 'bn' })
            });
            const data = await res.json();
            translations[section] = data.translatedText;
          } catch (e) {
            alert('Translation failed.');
            btn.textContent = '🇧🇩 Bangla';
            btn.disabled = false;
            return;
          }
        }
        
        textDiv.innerHTML = marked.parse(translations[section]);
        currentLang[section] = 'bn';
        btn.textContent = '🇬🇧 English';
        btn.disabled = false;
      } else {
        textDiv.innerHTML = marked.parse(rawData[section]);
        currentLang[section] = 'en';
        btn.textContent = '🇧🇩 Bangla';
      }
    }

    function showTab(tabName) {
      const tabs = ['daily', 'weekly', 'loyalty', 'growth'];
      tabs.forEach((t, i) => {
        document.getElementById(`tab-${t}`).style.display = tabName === t ? 'block' : 'none';
        const btn = document.querySelectorAll('.btn')[i];
        btn.className = tabName === t ? 'btn btn-primary' : 'btn';
        btn.style.background = tabName === t ? '' : '#e0e0e0';
      });
      
      if(tabName === 'weekly' && !window.weeklyLoaded) loadWeekly();
      if(tabName === 'loyalty' && !window.loyaltyLoaded) loadLoyalty();
      if(tabName === 'growth' && !window.growthLoaded) loadGrowth();
    }

    async function loadDaily() {
      const res = await fetch('/api/reports/daily');
      const data = await res.json();
      
      rawData.daily = data.aiSummary;
      document.getElementById('daily-text').innerHTML = marked.parse(data.aiSummary);
      
      let pos = 0, neu = 0, neg = 0;
      data.sentimentCounts.forEach(c => {
        if(c.label === 'positive') pos = c.count;
        if(c.label === 'neutral') neu = c.count;
        if(c.label === 'negative') neg = c.count;
      });

      new Chart(document.getElementById('dailyChart'), {
        type: 'doughnut',
        data: {
          labels: ['Positive', 'Neutral', 'Negative'],
          datasets: [{
            data: [pos, neu, neg],
            backgroundColor: ['#2ed573', '#f1c40f', '#ff4757']
          }]
        }
      });
    }

    async function loadWeekly() {
      window.weeklyLoaded = true;
      const res = await fetch('/api/reports/weekly');
      const data = await res.json();
      
      rawData.weekly = data.aiInsight;
      document.getElementById('weekly-text').innerHTML = marked.parse(data.aiInsight);
      document.getElementById('top-products').innerHTML = data.topProducts.map(p => `<li>${p.name} (${p.avg_rating.toFixed(1)}★)</li>`).join('');
      document.getElementById('worst-products').innerHTML = data.worstProducts.map(p => `<li>${p.name} (${p.avg_rating.toFixed(1)}★)</li>`).join('');
      
      // Peak Time Analysis
      const peakBody = document.getElementById('peak-time-body');
      if (data.peakTimeAnalysis && data.peakTimeAnalysis.length > 0) {
        peakBody.innerHTML = data.peakTimeAnalysis.map(t => {
          const total = t.total || 1;
          const pPct = ((t.positive / total) * 100).toFixed(0);
          const nPct = ((t.neutral / total) * 100).toFixed(0);
          const gPct = ((t.negative / total) * 100).toFixed(0);
          const hourNum = parseInt(t.hour);
          const ampm = hourNum >= 12 ? 'PM' : 'AM';
          const h12 = hourNum % 12 || 12;
          return `<tr>
            <td><strong>${h12}:00 ${ampm}</strong></td>
            <td>${t.total}</td>
            <td>⭐ ${t.avg_rating}</td>
            <td>
              <div class="mood-bar" title="Positive: ${pPct}%, Neutral: ${nPct}%, Negative: ${gPct}%">
                <div class="mood-pos" style="width:${pPct}%"></div>
                <div class="mood-neu" style="width:${nPct}%"></div>
                <div class="mood-neg" style="width:${gPct}%"></div>
              </div>
              <div style="font-size:11px;color:#888;margin-top:3px;">😊${t.positive} 😐${t.neutral} 😠${t.negative}</div>
            </td>
          </tr>`;
        }).join('');
      } else {
        peakBody.innerHTML = '<tr><td colspan="4" style="text-align:center;color:#999;">No peak time data available.</td></tr>';
      }
    }

    async function loadLoyalty() {
      window.loyaltyLoaded = true;
      const res = await fetch('/api/reports/loyalty');
      const data = await res.json();
      
      rawData.loyalty = data.aiPrediction;
      document.getElementById('loyalty-text').innerHTML = marked.parse(data.aiPrediction);
      document.getElementById('loyalty-high').textContent = data.loyaltyStats.high;
      document.getElementById('loyalty-medium').textContent = data.loyaltyStats.medium;
      document.getElementById('loyalty-risk').textContent = data.loyaltyStats.atRisk;
      
      // Customer Details Table
      const detailsBody = document.getElementById('loyalty-details-body');
      if (data.loyaltyData && data.loyaltyData.length > 0) {
        detailsBody.innerHTML = data.loyaltyData.map(c => {
          const badgeClass = c.loyalty === 'High' ? 'badge-high' : c.loyalty === 'Medium' ? 'badge-medium' : 'badge-risk';
          const avgRating = c.avg_rating ? c.avg_rating.toFixed(1) : 'N/A';
          const sentiment = c.avg_sentiment ? c.avg_sentiment.toFixed(2) : 'N/A';
          return `<tr>
            <td><strong>${c.customer_name}</strong></td>
            <td>${c.order_count}</td>
            <td>⭐ ${avgRating}</td>
            <td>${sentiment}</td>
            <td><span class="badge ${badgeClass}">${c.loyalty}</span></td>
          </tr>`;
        }).join('');
      } else {
        detailsBody.innerHTML = '<tr><td colspan="5" style="text-align:center;color:#999;">No customer data available.</td></tr>';
      }
    }

    async function loadGrowth() {
      window.growthLoaded = true;
      const res = await fetch('/api/reports/growth');
      const data = await res.json();
      
      rawData.growth = data.aiSuggestion;
      document.getElementById('growth-text').innerHTML = marked.parse(data.aiSuggestion);
      document.getElementById('growth-rev').textContent = '$' + data.totalRevenue;
      document.getElementById('growth-sent').textContent = data.avgSentiment;
    }

    loadDaily();
  </script>
</body>
</html>
