<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Admin - Global Reports</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    .tab-btn{padding:8px 20px;border:none;cursor:pointer;border-radius:4px;font-size:14px;transition:all .2s}
    .tab-btn.active{background:var(--primary);color:white}
    .tab-btn:not(.active){background:#e0e0e0;color:#333}
    .stat-mini{text-align:center;padding:15px;background:#f8f9fa;border-radius:8px}
    .stat-mini h4{font-size:13px;color:#888;margin-bottom:5px}
    .stat-mini .val{font-size:24px;font-weight:bold}
  </style>
</head>
<body>
  <nav class="navbar">
    <div class="container">
      <a href="/admin/dashboard" class="brand">👑 Admin Portal</a>
      <div class="nav-links"><a href="/logout" style="color: var(--danger);">Logout</a></div>
    </div>
  </nav>

  <div class="container dashboard-grid">
    <div class="sidebar">
      <ul class="sidebar-menu">
        <li><a href="/admin/dashboard">Overview</a></li>
        <li><a href="/admin/users">Users</a></li>
        <li><a href="/admin/shops">Shops</a></li>
        <li><a href="/admin/orders">All Orders</a></li>
        <li><a href="/admin/alerts">System Alerts</a></li>
        <li><a href="/admin/reports" class="active">Global AI Reports ✨</a></li>
      </ul>
    </div>

    <div class="main-content">
      <h2 style="margin-bottom: 20px;">Platform-Wide AI Analytics</h2>
      
      <div style="display: flex; gap: 10px; margin-bottom: 20px;">
        <button class="tab-btn active" id="btn-daily" onclick="showTab('daily')">📊 Daily Summary</button>
        <button class="tab-btn" id="btn-weekly" onclick="showTab('weekly')">📈 Weekly Insights</button>
        <button class="tab-btn" id="btn-monthly" onclick="showTab('monthly')">🗓️ Monthly Growth</button>
      </div>

      <!-- Daily Report Tab -->
      <div id="tab-daily">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
          <div class="card">
            <h3>Today's Sentiment Breakdown</h3>
            <div style="max-width: 250px; margin: 20px auto;">
              <canvas id="dailyPieChart"></canvas>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-top:15px;">
              <div class="stat-mini"><h4>Positive</h4><div class="val" style="color:var(--success)" id="d-pos">0</div></div>
              <div class="stat-mini"><h4>Neutral</h4><div class="val" style="color:var(--warning)" id="d-neu">0</div></div>
              <div class="stat-mini"><h4>Negative</h4><div class="val" style="color:var(--danger)" id="d-neg">0</div></div>
            </div>
          </div>
          <div class="card">
            <h3>Today's Reviews</h3>
            <div id="daily-reviews" style="max-height:350px;overflow-y:auto;margin-top:10px;">Loading...</div>
          </div>
        </div>
        <div class="card">
          <div style="background: #f8f9fa; padding: 20px; border-radius: 8px; border-left: 4px solid var(--primary);">
            <h4 style="color: var(--primary); margin-bottom: 10px;">✨ AI Daily Summary (All Shops)</h4>
            <div id="daily-text" style="font-style: italic; color: #555; line-height: 1.8;">Loading AI analysis...</div>
          </div>
        </div>
      </div>

      <!-- Weekly Report Tab -->
      <div id="tab-weekly" style="display: none;">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
          <div class="card">
            <h3 style="color: var(--success);">🏆 Top 5 Best Rated</h3>
            <ul id="top-products" style="padding-left: 20px; margin-top: 10px; line-height: 2;"></ul>
          </div>
          <div class="card">
            <h3 style="color: var(--danger);">⚠️ Needs Improvement</h3>
            <ul id="worst-products" style="padding-left: 20px; margin-top: 10px; color: var(--danger); line-height: 2;"></ul>
          </div>
        </div>
        <div class="card" style="margin-bottom: 20px;">
          <h3>Weekly Review Trend</h3>
          <div style="max-height: 300px;">
            <canvas id="weeklyBarChart"></canvas>
          </div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:15px;margin-bottom:20px;">
          <div class="stat-mini"><h4>Total Orders</h4><div class="val" style="color:var(--primary)" id="w-orders">0</div></div>
          <div class="stat-mini"><h4>Avg Rating</h4><div class="val" style="color:#f39c12" id="w-rating">-</div></div>
          <div class="stat-mini"><h4>Positive</h4><div class="val" style="color:var(--success)" id="w-pos">0</div></div>
          <div class="stat-mini"><h4>Negative</h4><div class="val" style="color:var(--danger)" id="w-neg">0</div></div>
        </div>
        <div class="card">
          <div style="background: #f8f9fa; padding: 20px; border-radius: 8px; border-left: 4px solid #3498db;">
            <h4 style="color: #3498db; margin-bottom: 10px;">✨ AI Weekly Insight (All Shops)</h4>
            <div id="weekly-text" style="color: #555; line-height: 1.8;">Loading...</div>
          </div>
        </div>
      </div>

      <!-- Monthly Report Tab -->
      <div id="tab-monthly" style="display: none;">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">
          <div class="card">
            <h3>Monthly Overview</h3>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:15px;margin-top:15px;">
              <div class="stat-mini"><h4>Total Revenue</h4><div class="val" style="color:var(--success)" id="m-rev">$0</div></div>
              <div class="stat-mini"><h4>Avg Sentiment</h4><div class="val" style="color:var(--primary)" id="m-sent">0</div></div>
            </div>
          </div>
          <div class="card">
            <h3>Customer Loyalty</h3>
            <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:15px;margin-top:15px;">
              <div class="stat-mini"><h4>High Loyalty</h4><div class="val" style="color:var(--success)" id="m-high">0</div></div>
              <div class="stat-mini"><h4>Medium</h4><div class="val" style="color:var(--warning)" id="m-med">0</div></div>
              <div class="stat-mini"><h4>At Risk</h4><div class="val" style="color:var(--danger)" id="m-risk">0</div></div>
            </div>
          </div>
        </div>
        <div class="card" style="margin-bottom: 20px;">
          <h3>Most Reviewed Items</h3>
          <div id="most-reviewed" style="margin-top: 10px;"></div>
        </div>
        <div class="card">
          <div style="background: #f8f9fa; padding: 20px; border-radius: 8px; border-left: 4px solid #9b59b6;">
            <h4 style="color: #9b59b6; margin-bottom: 10px;">✨ AI Business Growth Recommendations</h4>
            <div id="monthly-text" style="color: #555; line-height: 1.8;">Loading...</div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <script>
    let dailyChartInstance = null;
    let weeklyChartInstance = null;

    function showTab(tab) {
      document.getElementById('tab-daily').style.display = tab === 'daily' ? 'block' : 'none';
      document.getElementById('tab-weekly').style.display = tab === 'weekly' ? 'block' : 'none';
      document.getElementById('tab-monthly').style.display = tab === 'monthly' ? 'block' : 'none';
      document.getElementById('btn-daily').classList.toggle('active', tab === 'daily');
      document.getElementById('btn-weekly').classList.toggle('active', tab === 'weekly');
      document.getElementById('btn-monthly').classList.toggle('active', tab === 'monthly');
      if (tab === 'weekly' && !window._weeklyLoaded) loadWeekly();
      if (tab === 'monthly' && !window._monthlyLoaded) loadMonthly();
    }

    // ---- Daily ----
    async function loadDaily() {
      try {
        const res = await fetch('/api/reports/daily');
        const data = await res.json();

        document.getElementById('daily-text').innerHTML = (data.aiSummary || 'No data yet.').replace(/\n/g, '<br>');

        let pos = 0, neu = 0, neg = 0;
        (data.sentimentCounts || []).forEach(c => {
          if (c.label === 'positive') pos = c.count;
          if (c.label === 'neutral') neu = c.count;
          if (c.label === 'negative') neg = c.count;
        });
        document.getElementById('d-pos').textContent = pos;
        document.getElementById('d-neu').textContent = neu;
        document.getElementById('d-neg').textContent = neg;

        if (dailyChartInstance) dailyChartInstance.destroy();
        dailyChartInstance = new Chart(document.getElementById('dailyPieChart'), {
          type: 'doughnut',
          data: {
            labels: ['Positive', 'Neutral', 'Negative'],
            datasets: [{ data: [pos, neu, neg], backgroundColor: ['#2ed573', '#f1c40f', '#ff4757'] }]
          },
          options: { plugins: { legend: { position: 'bottom' } } }
        });

        const revContainer = document.getElementById('daily-reviews');
        if (data.reviews && data.reviews.length > 0) {
          revContainer.innerHTML = data.reviews.map(r => {
            const col = r.sentiment_label === 'positive' ? 'var(--success)' : r.sentiment_label === 'negative' ? 'var(--danger)' : 'var(--warning)';
            return `<div style="padding:10px;border-left:3px solid ${col};margin-bottom:8px;background:#fafafa;border-radius:4px;">
              <div style="display:flex;justify-content:space-between;font-size:13px;">
                <strong>${r.user_name}</strong>
                <span style="color:${col};text-transform:capitalize;">${r.sentiment_label || 'neutral'}</span>
              </div>
              <div style="color:#f1c40f;">${'★'.repeat(r.star_rating)}${'☆'.repeat(5 - r.star_rating)}</div>
              <div style="font-size:13px;color:#666;font-style:italic;">"${r.review_text || 'No text'}"</div>
            </div>`;
          }).join('');
        } else {
          revContainer.innerHTML = '<div style="color:#999;text-align:center;padding:20px;">No reviews received today.</div>';
        }
      } catch (e) {
        document.getElementById('daily-text').textContent = 'Failed to load daily report.';
      }
    }

    // ---- Weekly ----
    async function loadWeekly() {
      window._weeklyLoaded = true;
      try {
        const res = await fetch('/api/reports/weekly');
        const data = await res.json();

        document.getElementById('weekly-text').innerHTML = (data.aiInsight || 'No data yet.').replace(/\n/g, '<br>');
        document.getElementById('w-orders').textContent = data.totalOrders || 0;
        document.getElementById('w-rating').textContent = data.avgRating || '-';
        document.getElementById('w-pos').textContent = data.positiveCount || 0;
        document.getElementById('w-neg').textContent = data.negativeCount || 0;

        document.getElementById('top-products').innerHTML = (data.topProducts || []).map(p =>
          `<li><strong>${p.name}</strong> — ${p.avg_rating.toFixed(1)}★ (${p.review_count} reviews)</li>`
        ).join('') || '<li>No data yet</li>';

        document.getElementById('worst-products').innerHTML = (data.worstProducts || []).map(p =>
          `<li><strong>${p.name}</strong> — ${p.avg_rating.toFixed(1)}★ (${p.review_count} reviews)</li>`
        ).join('') || '<li>No data yet</li>';

        // Bar chart for review volume by day
        const days = (data.reviewsByDay || []);
        if (days.length > 0) {
          if (weeklyChartInstance) weeklyChartInstance.destroy();
          weeklyChartInstance = new Chart(document.getElementById('weeklyBarChart'), {
            type: 'bar',
            data: {
              labels: days.map(d => d.day),
              datasets: [
                { label: 'Positive', data: days.map(d => d.positive || 0), backgroundColor: '#2ed573' },
                { label: 'Neutral', data: days.map(d => d.neutral || 0), backgroundColor: '#f1c40f' },
                { label: 'Negative', data: days.map(d => d.negative || 0), backgroundColor: '#ff4757' }
              ]
            },
            options: { responsive: true, scales: { x: { stacked: true }, y: { stacked: true, beginAtZero: true } }, plugins: { legend: { position: 'bottom' } } }
          });
        }
      } catch (e) {
        document.getElementById('weekly-text').textContent = 'Failed to load weekly report.';
      }
    }

    // ---- Monthly ----
    async function loadMonthly() {
      window._monthlyLoaded = true;
      try {
        const res = await fetch('/api/reports/growth');
        const data = await res.json();

        document.getElementById('monthly-text').innerHTML = (data.aiSuggestion || 'No data yet.').replace(/\n/g, '<br>');
        document.getElementById('m-rev').textContent = '$' + (data.totalRevenue || '0.00');
        document.getElementById('m-sent').textContent = (data.avgSentiment || '0.50') + '/1.0';
        document.getElementById('m-high').textContent = data.loyaltyStats?.high || 0;
        document.getElementById('m-med').textContent = data.loyaltyStats?.medium || 0;
        document.getElementById('m-risk').textContent = data.loyaltyStats?.atRisk || 0;

        const reviewed = data.mostReviewed || [];
        document.getElementById('most-reviewed').innerHTML = reviewed.length > 0
          ? '<table style="width:100%;border-collapse:collapse;"><thead><tr style="background:#f8f9fa;"><th style="padding:8px;text-align:left;">Product</th><th style="padding:8px;text-align:center;">Reviews</th><th style="padding:8px;text-align:center;">Avg Rating</th></tr></thead><tbody>' +
            reviewed.map(r => `<tr style="border-bottom:1px solid #eee;"><td style="padding:8px;">${r.name}</td><td style="padding:8px;text-align:center;">${r.review_count}</td><td style="padding:8px;text-align:center;">${r.avg_rating.toFixed(1)}★</td></tr>`).join('') +
            '</tbody></table>'
          : '<div style="color:#999;text-align:center;">No review data available for this period.</div>';
      } catch (e) {
        document.getElementById('monthly-text').textContent = 'Failed to load monthly report.';
      }
    }

    loadDaily();
  </script>
</body>
</html>
