<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Admin - Users</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .custom-toast{position:fixed;bottom:30px;right:30px;padding:15px 25px;border-radius:4px;color:white;box-shadow:0 4px 10px rgba(0,0,0,.2);z-index:2000;display:none;animation:slideUp .3s ease}
    .toast-success{background:var(--success)}.toast-error{background:var(--danger)}
    @keyframes slideUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
    .modal-overlay{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.5);z-index:1500;align-items:center;justify-content:center}
    .modal-box{background:white;padding:30px;border-radius:10px;width:380px;max-width:90%;box-shadow:0 8px 25px rgba(0,0,0,.2);text-align:center}
  </style>
</head>
<body>
  <nav class="navbar">
    <div class="container">
      <a href="/admin/dashboard" class="brand">👑 Admin Portal</a>
      <div class="nav-links"><a href="/logout" style="color: var(--danger);">Logout</a></div>
    </div>
  </nav>

  <div class="container dashboard-grid">
    <div class="sidebar">
      <ul class="sidebar-menu">
        <li><a href="/admin/dashboard">Overview</a></li>
        <li><a href="/admin/users" class="active">Users</a></li>
        <li><a href="/admin/shops">Shops</a></li>
        <li><a href="/admin/orders">All Orders</a></li>
        <li><a href="/admin/alerts">System Alerts</a></li>
        <li><a href="/admin/reports">Global AI Reports ✨</a></li>
      </ul>
    </div>

    <div class="main-content">
      <h2 style="margin-bottom: 20px;">Manage Users</h2>
      
      <table style="width: 100%; border-collapse: collapse; background: white; border-radius: 8px; overflow: hidden; box-shadow: var(--shadow);">
        <thead style="background: var(--primary); color: white;">
          <tr>
            <th style="padding: 12px; text-align: left;">ID</th>
            <th style="padding: 12px; text-align: left;">Name</th>
            <th style="padding: 12px; text-align: left;">Email</th>
            <th style="padding: 12px; text-align: left;">Role</th>
            <th style="padding: 12px; text-align: left;">Status</th>
            <th style="padding: 12px; text-align: left;">Actions</th>
          </tr>
        </thead>
        <tbody id="users-table">
          <!-- populated via JS -->
        </tbody>
      </table>
    </div>
  </div>

  <!-- Confirm Modal -->
  <div class="modal-overlay" id="confirmModal">
    <div class="modal-box">
      <h3 id="confirmText">Change user status?</h3>
      <div style="display:flex;gap:10px;justify-content:center;margin-top:20px;">
        <button class="btn btn-primary" id="confirmYesBtn">Yes, do it</button>
        <button class="btn" style="background:#e0e0e0;color:#333;" onclick="closeConfirm()">Cancel</button>
      </div>
    </div>
  </div>

  <!-- Toast -->
  <div class="custom-toast" id="toast"></div>

  <script>
    function showToast(msg, type = 'success') {
      const t = document.getElementById('toast');
      t.textContent = msg;
      t.className = 'custom-toast toast-' + type;
      t.style.display = 'block';
      setTimeout(() => { t.style.display = 'none'; }, 3000);
    }

    let pendingUserId = null;
    let pendingAction = null;

    function showConfirmModal(userId, isActive, action = 'toggle') {
      pendingUserId = userId;
      pendingAction = action;
      if (action === 'delete') {
        document.getElementById('confirmText').textContent = 'Are you sure you want to permanently delete this user and all their data?';
        document.getElementById('confirmYesBtn').style.background = 'var(--danger)';
      } else {
        document.getElementById('confirmText').textContent = isActive
          ? 'Are you sure you want to deactivate this user?'
          : 'Are you sure you want to activate this user?';
        document.getElementById('confirmYesBtn').style.background = 'var(--primary)';
      }
      document.getElementById('confirmModal').style.display = 'flex';
    }

    function closeConfirm() {
      document.getElementById('confirmModal').style.display = 'none';
      pendingUserId = null;
      pendingAction = null;
    }

    document.getElementById('confirmYesBtn').addEventListener('click', async () => {
      if (!pendingUserId) return;
      const id = pendingUserId;
      const action = pendingAction;
      closeConfirm();
      
      try {
        let res, data;
        if (action === 'delete') {
          res = await fetch(`/api/admin/users/${id}`, { method: 'DELETE' });
        } else {
          res = await fetch(`/api/admin/users/${id}/toggle`, { method: 'PATCH' });
        }
        data = await res.json();
        if (data.success) {
          showToast(data.message || 'User status updated successfully!');
        } else {
          showToast(data.error || 'Failed to update user', 'error');
        }
      } catch (e) {
        showToast('Network error', 'error');
      }
      loadUsers();
    });

    async function loadUsers() {
      const res = await fetch('/api/admin/users');
      const data = await res.json();
      
      document.getElementById('users-table').innerHTML = data.users.map(u => `
        <tr style="border-bottom: 1px solid #eee;">
          <td style="padding: 12px;">#${u.id}</td>
          <td style="padding: 12px;">${u.name}</td>
          <td style="padding: 12px;">${u.email}</td>
          <td style="padding: 12px; text-transform: capitalize;">${u.role}</td>
          <td style="padding: 12px;">
            <span style="color: ${u.is_active ? 'var(--success)' : 'var(--danger)'}; font-weight: bold;">
              ${u.is_active ? 'Active' : 'Deactivated'}
            </span>
          </td>
          <td style="padding: 12px;">
            ${u.role !== 'admin' ? `
              <div style="display: flex; gap: 5px;">
                <button class="btn" style="padding: 4px 8px; font-size: 12px; background: ${u.is_active ? 'var(--warning)' : 'var(--success)'}; color: white;" onclick="showConfirmModal(${u.id}, ${u.is_active}, 'toggle')">
                  ${u.is_active ? 'Deactivate' : 'Activate'}
                </button>
                <button class="btn" style="padding: 4px 8px; font-size: 12px; background: var(--danger); color: white;" onclick="showConfirmModal(${u.id}, null, 'delete')">
                  Delete
                </button>
              </div>
            ` : '-'}
          </td>
        </tr>
      `).join('');
    }

    loadUsers();
  </script>
</body>
</html>
