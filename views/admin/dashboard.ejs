<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Admin Dashboard</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="container">
      <a href="/admin/dashboard" class="brand">👑 Admin Portal</a>
      <div class="nav-links">
        <a href="/logout" style="color: var(--danger);">Logout</a>
      </div>
    </div>
  </nav>

  <div class="container dashboard-grid">
    <div class="sidebar">
      <ul class="sidebar-menu">
        <li><a href="/admin/dashboard" class="active">Overview</a></li>
        <li><a href="/admin/users">Users</a></li>
        <li><a href="/admin/shops">Shops</a></li>
        <li><a href="/admin/orders">All Orders</a></li>
        <li><a href="/admin/alerts">System Alerts</a></li>
        <li><a href="/admin/reports">Global AI Reports ✨</a></li>
      </ul>
    </div>

    <div class="main-content">
      <h2 style="margin-bottom: 20px;">Platform Overview</h2>

      <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 30px;">
        <div class="card" style="text-align: center;">
          <h3 style="color: var(--text-light); font-size: 14px;">Total Users</h3>
          <div id="stat-users" style="font-size: 32px; font-weight: bold; color: var(--primary);">0</div>
        </div>
        <div class="card" style="text-align: center;">
          <h3 style="color: var(--text-light); font-size: 14px;">Active Shops</h3>
          <div id="stat-shops" style="font-size: 32px; font-weight: bold; color: var(--primary);">0</div>
        </div>
        <div class="card" style="text-align: center;">
          <h3 style="color: var(--text-light); font-size: 14px;">Total Orders</h3>
          <div id="stat-orders" style="font-size: 32px; font-weight: bold; color: var(--success);">0</div>
        </div>
        <div class="card" style="text-align: center;">
          <h3 style="color: var(--text-light); font-size: 14px;">Total Revenue</h3>
          <div id="stat-rev" style="font-size: 32px; font-weight: bold; color: var(--success);">$0</div>
        </div>
      </div>

      <div class="card">
        <h3>Platform AI Summary (Today)</h3>
        <hr style="margin: 10px 0;">
        <div id="ai-summary" style="font-style: italic; color: #555; line-height: 1.8;">
          Loading AI overview of the platform...
        </div>
      </div>
    </div>
  </div>

  <script>
    async function loadAdminStats() {
      const res = await fetch('/api/admin/stats');
      const stats = await res.json();
      
      document.getElementById('stat-users').textContent = stats.totalUsers;
      document.getElementById('stat-shops').textContent = stats.totalShops;
      document.getElementById('stat-orders').textContent = stats.totalOrders;
      document.getElementById('stat-rev').textContent = '$' + stats.totalRevenue.toFixed(2);

      const reportRes = await fetch('/api/reports/daily');
      const report = await reportRes.json();
      document.getElementById('ai-summary').innerHTML = report.aiSummary.replace(/\n/g, '<br>');
    }

    loadAdminStats();
  </script>
</body>
</html>
